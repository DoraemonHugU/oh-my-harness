{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/tree.mjs\" --hook",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; if ($LASTEXITCODE -eq 0) { node (Join-Path $root '.codex/hooks/tree.mjs') --hook }\"",
            "timeout": 10,
            "statusMessage": "Updating tree"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/tree.mjs\" --hook",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; if ($LASTEXITCODE -eq 0) { node (Join-Path $root '.codex/hooks/tree.mjs') --hook }\"",
            "timeout": 10,
            "statusMessage": "Updating tree"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/tree.mjs\" --hook",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; if ($LASTEXITCODE -eq 0) { node (Join-Path $root '.codex/hooks/tree.mjs') --hook }\"",
            "timeout": 10,
            "statusMessage": "Checking tree"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/tree.mjs\" --hook",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; if ($LASTEXITCODE -eq 0) { node (Join-Path $root '.codex/hooks/tree.mjs') --hook }\"",
            "timeout": 10,
            "statusMessage": "Refreshing tree"
          }
        ]
      }
    ]
  }
}
